generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}


model Guild {
  id     String @id @default(uuid())
  name   String
  region String?
  headquarters String?
  hunters Hunter[]
}

model Hunter {
  id    String @id @default(uuid())
  name  String
  rank  Int
  experiencePoints Int

  guildId   String
  guild Guild @relation(fields: [guildId], references: [id])
}